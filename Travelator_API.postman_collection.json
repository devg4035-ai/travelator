{
  "info": {
    "name": "Travelator API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for Travelator Node.js + Express + MongoDB API"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "userId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "orderId", "value": "" }
